rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;
    }

    match /sessions/{session} {
      allow read: if request.auth != null;
      allow create: if request.auth.uid == request.resource.data.tutorId;
      allow update: if
        (request.auth.uid == resource.data.tutorId && resource.data.status == 'open') ||
        (request.auth.uid == request.resource.data.studentId &&
         resource.data.status == 'open' &&
         request.resource.data.status == 'booked');
      allow delete: if false;
    }

    match /resources/{resource} {
      allow read: if request.auth != null;
      allow create, update: if request.auth.uid == resource.data.uploadedBy;
    }

    match /reviews/{review} {
      allow read: if request.auth != null;
      allow create: if request.auth.uid == request.resource.data.fromUserId;
    }
  }
}
